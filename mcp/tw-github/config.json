{
  "$schema": "../../config/mcp-server.schema.json",
  "server_name": "tw-github",
  "package": "@modelcontextprotocol/server-github",
  "package_manager": "npx",
  "env_prefix": "TW_GITHUB",
  "required_env": [
    {
      "var": "TW_GITHUB_TOKEN",
      "maps_to": "GITHUB_PERSONAL_ACCESS_TOKEN",
      "description": "GitHub Personal Access Token with repo scope"
    }
  ],
  "optional_env": [],
  "options": {
    "default_owner": {
      "type": "string",
      "description": "Default GitHub org/user when not specified in tool calls",
      "default": ""
    },
    "default_repo": {
      "type": "string",
      "description": "Default repository name when not specified in tool calls",
      "default": ""
    }
  },
  "tools": [
    "github_get_file_contents",
    "github_create_or_update_file",
    "github_push_files",
    "github_create_repository",
    "github_search_repositories",
    "github_create_issue",
    "github_list_issues",
    "github_update_issue",
    "github_add_issue_comment",
    "github_create_pull_request",
    "github_list_pull_requests",
    "github_get_pull_request",
    "github_merge_pull_request",
    "github_create_branch",
    "github_list_commits",
    "github_search_code",
    "github_search_issues"
  ]
}
