# tw-ai-toolkit — Environment Variables
# Copy this file to .env in your consumer repo and fill in the values.
# Never commit .env to version control.

# ─── General ─────────────────────────────────────────────────────────────────

# Toolkit environment: development | staging | production
TW_TOOLKIT_ENV=development

# ─── MCP Servers ──────────────────────────────────────────────────────────────
# Uncomment and fill in credentials for the MCP servers you enable in config.json

# GitHub MCP Server
# TW_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Jira MCP Server
# TW_JIRA_HOST=https://your-org.atlassian.net
# TW_JIRA_EMAIL=you@company.com
# TW_JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Slack MCP Server
# TW_SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxx

# ─── Secrets Manager (optional) ───────────────────────────────────────────────
# If using a central secrets manager instead of per-repo .env files

# AWS Secrets Manager
# TW_SECRETS_PROVIDER=aws
# AWS_REGION=us-east-1
# AWS_SECRET_NAME=tw-ai-toolkit/production

# HashiCorp Vault
# TW_SECRETS_PROVIDER=vault
# VAULT_ADDR=https://vault.your-org.com
# VAULT_TOKEN=hvs.xxxxxxxxxxxxxxxxxxxx
