#!/usr/bin/env bash
# tw-ai-toolkit pre-commit hook
# Regenerates registry.json and context snapshots whenever component files are staged.
# Installed via: bash scripts/install-git-hooks.sh

TOOLKIT_ROOT="$(git rev-parse --show-toplevel)"

COMPONENT_PATHS_PATTERN='^(skills|agents|prompts|rules|hooks|mcp)/'

if git diff --cached --name-only | grep -qE "$COMPONENT_PATHS_PATTERN"; then
    echo "[tw-ai-toolkit] Component changes detected — syncing context..."

    bash "$TOOLKIT_ROOT/scripts/sync-registry.sh" || {
        echo "[tw-ai-toolkit] ERROR: sync-registry.sh failed. Commit aborted." >&2
        exit 1
    }

    bash "$TOOLKIT_ROOT/scripts/sync-snapshots.sh" || {
        echo "[tw-ai-toolkit] ERROR: sync-snapshots.sh failed. Commit aborted." >&2
        exit 1
    }

    # Stage the auto-generated files so they land in the same commit
    git add \
        "$TOOLKIT_ROOT/registry.json" \
        "$TOOLKIT_ROOT/context/snapshot.md" \
        "$TOOLKIT_ROOT/context/snapshots/" \
        "$TOOLKIT_ROOT/context/CHECKPOINT.md"

    echo "[tw-ai-toolkit] Context snapshots staged and ready."
fi
